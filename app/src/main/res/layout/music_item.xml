<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/_5sdp"
    android:layout_marginVertical="@dimen/_3sdp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_musicImg"
        android:layout_width="@dimen/_45sdp"
        android:layout_height="@dimen/_45sdp"
        app:cardCornerRadius="@dimen/_12sdp"
        app:strokeColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <ImageView
            android:id="@+id/iv_music"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_music_default"
            />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_music"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Music Name"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginStart="@dimen/_10sdp"
        app:layout_constraintStart_toEndOf="@+id/cv_musicImg"
        app:layout_constraintTop_toTopOf="@+id/cv_musicImg"
        app:layout_constraintBottom_toTopOf="@+id/tv_album"
        app:layout_constraintEnd_toStartOf="@+id/tv_duration"
        />

    <TextView
        android:id="@+id/tv_album"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Album Name"
        android:textSize="@dimen/_12ssp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@+id/tv_music"
        app:layout_constraintBottom_toBottomOf="@+id/cv_musicImg"
        app:layout_constraintTop_toBottomOf="@id/tv_music"
        app:layout_constraintEnd_toEndOf="@+id/tv_music"
        />

    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="03:14"
        android:textStyle="bold"
        android:textSize="@dimen/_10ssp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>